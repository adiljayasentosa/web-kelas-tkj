# =============================================================
# Firebase Client SDK — aman diekspos ke browser (wajib prefix NEXT_PUBLIC_)
# Nilai diambil dari Firebase Console > Project Settings > General > Your apps
# =============================================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# =============================================================
# Firebase Admin SDK — HANYA dipakai di server (Server Action/API Route)
# JANGAN PERNAH diberi prefix NEXT_PUBLIC_.
# Nilai berupa JSON service account key (diambil dari Firebase Console >
# Project Settings > Service Accounts > Generate new private key),
# disimpan sebagai satu baris string di sini.
# =============================================================
FIREBASE_SERVICE_ACCOUNT_KEY=
